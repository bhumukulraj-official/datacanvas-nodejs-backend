# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primary Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=portfolio_dev

# Test Database
DB_TEST_NAME=portfolio_test
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_USER=postgres
DB_TEST_PASSWORD=postgres

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=portfolio:
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Authentication
JWT_SECRET=temp-jwt-secret-please-change-in-production
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
WS_RATE_LIMIT_MAX_MESSAGES=50
WS_RATE_LIMIT_WINDOW_MS=60000

# reCAPTCHA (Google)
RECAPTCHA_SECRET_KEY=<your-recaptcha-secret-key>
RECAPTCHA_SITE_KEY=<your-recaptcha-site-key>

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# =============================================================================
# STORAGE & MEDIA
# =============================================================================
# Local Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=storage
UPLOAD_MAX_SIZE=5242880
UPLOAD_BASE_URL=/uploads
UPLOAD_PATH=uploads/

# AWS S3 (if storage type is 's3')
STORAGE_S3_BUCKET=<your-s3-bucket-name>
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=<your-s3-access-key>
STORAGE_S3_SECRET_KEY=<your-s3-secret-key>

# =============================================================================
# EMAIL SERVICE
# =============================================================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASSWORD=<your-secure-email-password>
MAIL_FROM=noreply@example.com
MAIL_SECURE=false

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================
WS_PATH=/api/v1/ws
WS_MAX_PAYLOAD_SIZE=1048576
WS_HEARTBEAT_INTERVAL=30000

# =============================================================================
# PRODUCTION ONLY
# =============================================================================
# SSL Configuration (uncomment in production)
# SSL_CERT_PATH=/path/to/cert
# SSL_KEY_PATH=/path/to/key 